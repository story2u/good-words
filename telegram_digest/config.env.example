# Telegram Bot API credentials.
# Create a bot with @BotFather, then send a message to the bot before using a private chat ID.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Defaults target the completed Jianlai excerpt file.
# Relative paths are resolved from the command's working directory.
GOOD_WORDS_SOURCE=./categories/网络文学/excerpts/剑来.md
GOOD_WORDS_CATEGORY=网络文学
GOOD_WORDS_BOOK=剑来

# Beijing time is UTC+8. Asia/Shanghai is the standard IANA timezone name.
GOOD_WORDS_TIMEZONE=Asia/Shanghai
GOOD_WORDS_SCHEDULE=20:00
GOOD_WORDS_LIMIT=5

# Local SQLite database. This path is ignored by git.
GOOD_WORDS_DB=./telegram_digest/data/good_words.sqlite3
